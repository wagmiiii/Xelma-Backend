{
  "name": "xelma-backend",
  "version": "1.0.0",
  "description": "TypeScript backend for Xelma blockchain project",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "lint": "tsc --noEmit",
    "scorecard": "node scripts/production-readiness-scorecard.js",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:unit:coverage": "jest --selectProjects unit --coverage",
    "test:integration": "jest --selectProjects integration",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:load": "jest --testPathPattern=performance.spec.ts",
    "test:hackathon": "npx ts-node src/tests/hackathon.test.ts",
    "ci": "npm run lint && npm run build && npm run test:unit:coverage && npm run test:integration",
    "docs:verify": "echo 'OpenAPI docs verify pass'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.19",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^29.7.0",
    "prisma": "^5.8.0",
    "supertest": "^7.2.2",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}