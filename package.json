{
  "name": "xelma-backend",
  "version": "1.0.0",
  "description": "TypeScript backend for Xelma blockchain project",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "tsc --noEmit",
    "scorecard": "node scripts/production-readiness-scorecard.js",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:unit:coverage": "jest --selectProjects unit --coverage",
    "test:integration": "jest --selectProjects integration",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:load": "jest --testPathPattern=performance.spec.ts",
    "test:hackathon": "npx ts-node src/tests/hackathon.test.ts",
    "ci": "npm run lint && npm run build && npm run test:unit:coverage && npm run test:integration",
    "docs:openapi": "node dist/scripts/generate-openapi.js",
    "docs:verify": "node scripts/verify-openapi-sync.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:prepare": "prisma generate && prisma migrate deploy",
    "dev:hackathon": "ts-node-dev --respawn --transpile-only src/server.ts",
    "smoke-test": "node scripts/smoke-test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@stellar/stellar-sdk": "^16.0.1",
    "@tevalabs/xelma-bindings": "file:vendor/xelma-bindings",
    "axios": "^1.16.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "node-cron": "^4.5.0",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "redis": "^6.0.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.19",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "jest": "^29.7.0",
    "openapi-to-postmanv2": "^6.1.0",
    "prisma": "^5.8.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
