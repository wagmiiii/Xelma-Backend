# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────
# To reproduce Render production behavior locally, see the
# "Render parity local profile" section of README.md and use
# `npm run start:render-parity`. That mode requires the same vars
# Render uses: NODE_ENV=production, CLIENT_URL set (no wildcard CORS),
# JWT_SECRET, DATABASE_URL, plus the SOROBAN_* secrets if Soroban is on.
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Client URL (required in production)
# The origin allowed for Socket.IO CORS. Must be set in production.
# In development, omitting this allows all origins (useful for local dev).
CLIENT_URL=http://localhost:5173

# Additional allowed origins for Socket.IO (comma-separated, optional)
# Use this to allow connections from multiple frontend domains.
# Example: https://app.example.com,https://staging.example.com
# ALLOWED_ORIGINS=

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/xelma_db

# Prisma / Postgres connection pool tuning
# These env vars are merged into DATABASE_URL query params at startup.
# Production-safe defaults are applied if unset.
#
# DB_CONNECTION_LIMIT: Maximum number of DB connections Prisma will open.
# - Local dev default is conservative to avoid exhausting local Postgres.
DB_CONNECTION_LIMIT=10
#
# DB_POOL_TIMEOUT_SECONDS: How long to wait for a connection from the pool.
DB_POOL_TIMEOUT_SECONDS=10
#
# DB_CONNECT_TIMEOUT_SECONDS: How long to wait when establishing a new connection.
DB_CONNECT_TIMEOUT_SECONDS=10
#
# DB_STATEMENT_TIMEOUT_MS: Server-side query timeout (0 disables).
DB_STATEMENT_TIMEOUT_MS=0
#
# DB_PGBOUNCER: Set true if connecting via PgBouncer transaction pooling.
DB_PGBOUNCER=false

# JWT Configuration
# IMPORTANT: Change this to a strong, random secret in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d

# Xelma Bindings – API Key
# Required to authenticate requests made with @tevalabs/xelma-bindings
# Obtain your key from the TevaLabs dashboard or from the project maintainers
XELMA_API_KEY=your-xelma-api-key-here

# Soroban Network Configuration
# Options: 'mainnet' or 'testnet'
SOROBAN_NETWORK=testnet

# Soroban Smart Contract Configuration
# RPC endpoint for Soroban contract calls
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Deployed Xelma prediction market contract ID
# Get this from the Xelma-Blockchain deployment
SOROBAN_CONTRACT_ID=your-contract-id-here

# Admin keypair secret key (for creating rounds)
# This should be the admin address used when initializing the contract
SOROBAN_ADMIN_SECRET=S...your-admin-secret-key-here

# Oracle keypair secret key (for resolving rounds)
# This should be the oracle address used when initializing the contract
SOROBAN_ORACLE_SECRET=S...your-oracle-secret-key-here

# Round Scheduler (cron for creating/closing rounds)
# Set to "true" to enable scheduled round creation every 4 min and locking every 30s
ROUND_SCHEDULER_ENABLED=false
# Game mode for scheduled rounds: UP_DOWN or LEGENDS
ROUND_SCHEDULER_MODE=UP_DOWN

# API-only startup mode (no background workers)
# Set to "true" to run the HTTP API without oracle polling, cron schedulers,
# or WebSocket price-tick broadcasts. Useful for split deployments
# (one worker process owns crons; others serve HTTP) and for safer
# local debugging when you don't want background jobs running.
API_ONLY=false

# Price Oracle Configuration
# Interval between price updates from CoinGecko (milliseconds)
ORACLE_POLLING_INTERVAL_MS=10000
# Network timeout for oracle requests (milliseconds)
ORACLE_REQUEST_TIMEOUT_MS=5000
# Maximum retry attempts for failed oracle requests
ORACLE_MAX_RETRIES=3
# Threshold for considering price data stale (milliseconds)
ORACLE_STALENESS_THRESHOLD_MS=60000

# -----------------------
# Redis Cache (Optional)
# -----------------------
# Leave undefined/empty to disable Redis-backed caching entirely.
REDIS_URL=redis://localhost:6379

# Set to "false" to disable Redis caching even if REDIS_URL is present.
REDIS_CACHE_ENABLED=true

# Leaderboard pagination cache TTL (seconds).
LEADERBOARD_CACHE_TTL_SECONDS=60

# Static educational guides cache TTL (seconds).
EDUCATION_GUIDES_CACHE_TTL_SECONDS=86400

# Prefix for all Redis cache keys.
REDIS_CACHE_PREFIX=xelma:cache

# Cooldown after a failed Redis connect/ping (ms) before retrying.
REDIS_FAIL_COOLDOWN_MS=10000

# -----------------------
# Data Retention Policies
# -----------------------
# Enable/disable retention policy for auth challenges
RETENTION_AUTH_CHALLENGES_ENABLED=true
# Time-to-live for auth challenges in days (default: 7 days)
RETENTION_AUTH_CHALLENGES_TTL_DAYS=7

# Enable/disable retention policy for chat messages
RETENTION_CHAT_MESSAGES_ENABLED=true
# Time-to-live for chat messages in days (default: 90 days)
RETENTION_CHAT_MESSAGES_TTL_DAYS=90

# Batch size for deletion operations (default: 1000)
RETENTION_BATCH_SIZE=1000
